#!/busybox sh

/busybox mkdir -p /bin
/busybox cp /busybox /bin/busybox
/bin/busybox --install -s /bin
export PATH=/bin

mkdir -p /proc /sys /dev
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t tmpfs tmpfs /dev

printf "\033[1;34m"
printf "  __  __                 _    _____  ____________ \n"
printf " |  \/  |               (_)  |  _  |(__  /  _  / \n"
printf " | .  . | __ _ _   _ _ __ _  | |/' |  / /| |/' / \n"
printf " | |\/| |/ _' | | | | '__| | |  /| | / / |  /|   \n"
printf " | |  | | (_| | |_| | |  | | \ |_/ /./ /_\ |_/ / \n"
printf " \_|  |_/\__,_|\__,_|_|  |_|  \___/ \_\_(_)___/  \n"
printf "\033[0m\n"
printf "\033[1;36m  Linux in your browser — have fun exploring!\033[0m\n"
printf "\n"
printf "\033[1;33m  Kernel  :\033[0m \033[1;32m%s\033[0m\n" "$(uname -r)"
printf "\033[1;33m  Machine :\033[0m \033[1;32m%s\033[0m\n" "$(uname -m)"
printf "\033[1;33m  Uptime  :\033[0m \033[1;32m%s\033[0m\n" "$(uptime | sed 's/.*up //' | sed 's/,.*//')"
printf "\033[1;33m  Memory  :\033[0m \033[1;32m%s\033[0m\n" "$(free -h | awk '/^Mem:/{print $3 " used / " $2 " total"}')"
printf "\033[1;33m  Disk    :\033[0m \033[1;32m%s\033[0m\n" "$(df -h / | awk 'NR==2{print $3 " used / " $2 " total"}')"
printf "\n"

echo 4 > /proc/sys/kernel/printk

exec sh